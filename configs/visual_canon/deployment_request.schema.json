{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narrative-character-canon.local/schemas/deployment_request.schema.json",
  "title": "NCC Visual Canon Deployment Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "operation_id", "expected_git_head", "character_id", "prompt_id",
    "test_number", "scene_id", "version", "source_image_path", "source_image_sha256",
    "planned_output_path", "selected", "human_approval", "approval_evidence", "verdict",
    "role", "storage", "content_tier", "reference_paths", "prompt_linkage",
    "expected_file_hashes", "expected_absent_paths", "updates"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "operation_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$" },
    "expected_git_head": { "$ref": "#/$defs/gitHash" },
    "character_id": { "$ref": "#/$defs/characterId" },
    "character_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/characterId" }
    },
    "prompt_id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*_V[0-9]+$" },
    "test_number": { "type": "integer", "minimum": 1 },
    "scene_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "version": { "type": "string", "pattern": "^V[0-9]+$" },
    "variant_label": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
    "backend": { "type": "string", "minLength": 1 },
    "source_image_path": { "type": "string", "minLength": 1 },
    "source_image_sha256": { "$ref": "#/$defs/sha256" },
    "planned_output_path": { "$ref": "#/$defs/repoPngPath" },
    "selected": { "const": true },
    "human_approval": { "const": true },
    "approval_evidence": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/repoEvidence" },
          { "$ref": "#/$defs/voyageEvidence" },
          { "$ref": "#/$defs/commitEvidence" }
        ]
      }
    },
    "verdict": { "enum": ["APPROVED_AS_TEST", "APPROVED_AS_CANON"] },
    "role": { "enum": ["MAIN", "ALT"] },
    "storage": { "const": "repo_tracked" },
    "content_tier": { "const": "public_filtered" },
    "reference_paths": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/repoPath" }
    },
    "prompt_linkage": {
      "type": "object", "additionalProperties": false,
      "required": ["prompt_index_path", "prompt_index_required_text", "prompt_source_path", "prompt_heading"],
      "properties": {
        "prompt_index_path": { "$ref": "#/$defs/repoPath" },
        "prompt_index_required_text": { "type": "string", "minLength": 1 },
        "prompt_source_path": { "$ref": "#/$defs/repoPath" },
        "prompt_heading": { "type": "string", "minLength": 1 }
      }
    },
    "expected_file_hashes": {
      "type": "object", "minProperties": 5,
      "propertyNames": { "$ref": "#/$defs/repoPath" },
      "additionalProperties": { "$ref": "#/$defs/sha256" }
    },
    "expected_absent_paths": {
      "type": "array", "minItems": 1, "maxItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/repoPngPath" }
    },
    "updates": {
      "type": "object", "additionalProperties": false,
      "required": ["prompt_record", "test_results", "reference_presets", "canon_index"],
      "properties": {
        "prompt_record": {
          "type": "object", "additionalProperties": false,
          "required": ["registry_path", "set_fields"],
          "properties": {
            "registry_path": { "$ref": "#/$defs/repoPath" },
            "set_fields": {
              "type": "object", "additionalProperties": false,
              "required": ["selected", "human_approval", "verdict", "role", "storage", "content_tier", "deployed", "output_path"],
              "properties": {
                "selected": { "const": true },
                "human_approval": { "const": true },
                "verdict": { "enum": ["APPROVED_AS_TEST", "APPROVED_AS_CANON"] },
                "role": { "enum": ["MAIN", "ALT"] },
                "storage": { "const": "repo_tracked" },
                "content_tier": { "const": "public_filtered" },
                "deployed": { "const": true },
                "output_path": { "$ref": "#/$defs/repoPngPath" }
              }
            }
          }
        },
        "test_results": { "$ref": "#/$defs/markdownUpdate" },
        "reference_presets": {
          "type": "object", "additionalProperties": false,
          "required": ["path", "container_path", "preset_id", "preset_value"],
          "properties": {
            "path": { "$ref": "#/$defs/repoPath" },
            "container_path": {
              "type": "array", "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "preset_id": { "type": "string", "minLength": 1 },
            "preset_value": { "type": "object" }
          }
        },
        "canon_index": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/markdownUpdate" }
          ]
        }
      }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "gitHash": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "characterId": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
    "repoPath": {
      "type": "string", "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "repoPngPath": {
      "type": "string",
      "pattern": "^AI_CHARACTERS/(?:[^/]+/|_[^/]+/[^/]+/)07_generated/.+\\.png$"
    },
    "requiredText": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "repoEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "assertion", "path", "sha256", "required_text"],
      "properties": {
        "kind": { "const": "repo_path" },
        "assertion": { "const": "human_selected_and_approved" },
        "path": { "$ref": "#/$defs/repoPath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "required_text": { "$ref": "#/$defs/requiredText" }
      }
    },
    "voyageEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "assertion", "path", "decision_id", "sha256", "required_text"],
      "properties": {
        "kind": { "const": "voyage_decision" },
        "assertion": { "const": "human_selected_and_approved" },
        "path": { "const": ".voyage/DECISIONS.md" },
        "decision_id": { "type": "string", "pattern": "^D-[0-9]{3,}$" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "required_text": { "$ref": "#/$defs/requiredText" }
      }
    },
    "commitEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "assertion", "commit_hash", "path", "required_text"],
      "properties": {
        "kind": { "const": "commit" },
        "assertion": { "const": "human_selected_and_approved" },
        "commit_hash": { "$ref": "#/$defs/gitHash" },
        "path": { "$ref": "#/$defs/repoPath" },
        "required_text": { "$ref": "#/$defs/requiredText" }
      }
    },
    "markdownUpdate": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "unique_anchor", "entry_markdown"],
      "properties": {
        "path": { "$ref": "#/$defs/repoPath" },
        "unique_anchor": { "type": "string", "minLength": 1 },
        "entry_markdown": { "type": "string", "minLength": 1 }
      }
    }
  }
}
